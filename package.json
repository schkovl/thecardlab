{
  "name": "thecardlab-monorepo",
  "private": true,
  "scripts": {
    "build": "cd artifacts/thecardlab && pnpm build",
    "typecheck": "pnpm -r --if-present run typecheck"
  },
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": "20.x"
  },
  "pnpm": {
    "catalog": {
      "@replit/wite-plugin-cartographer": "*"
    },
    "onlyBuiltDependencies": ["esbuild", "esbuild-plugin-pino"]
  }
}
